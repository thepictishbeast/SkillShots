# --- Skill Shots API — example env ---
# Copy to .env, fill in real values, NEVER commit the filled file.

NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Postgres
DATABASE_URL=postgresql://skillshots:skillshots@localhost:5432/skillshots?schema=public

# JWT — REQUIRED ≥64 chars of CSPRNG output. `openssl rand -base64 64` is fine.
JWT_ACCESS_SECRET=replace_me_with_openssl_rand_base64_64
JWT_REFRESH_SECRET=replace_me_with_DIFFERENT_openssl_rand_base64_64
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# CORS allow-list (comma-separated origins)
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# S3 / R2 / Minio
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=skillshots-videos
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_HOSTS=cdn.skillshots.app,media.skillshots.app,localhost:9000

# Upload constraints
MAX_VIDEO_BYTES=104857600
MAX_VIDEO_DURATION_SECONDS=120
ALLOWED_VIDEO_MIME=video/mp4,video/webm,video/quicktime

# Stripe Connect (skeleton — fill before Phase 3)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PLATFORM_FEE_BPS=1250

# Rate limiting
RL_GLOBAL_PER_MIN=600
RL_AUTH_PER_MIN=20
RL_VOTE_PER_MIN=60

# Age gate (years). 18 default; some markets require 21.
MIN_AGE_YEARS=18
