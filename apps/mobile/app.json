{
  "expo": {
    "name": "Skill Shots",
    "slug": "skill-shots",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "skillshots",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "resizeMode": "cover",
      "backgroundColor": "#0B0F14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.skillshots.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Record proof and attempt videos for challenges.",
        "NSPhotoLibraryUsageDescription": "Pick previously recorded videos to submit.",
        "NSPhotoLibraryAddUsageDescription": "Save the videos you record."
      }
    },
    "android": {
      "package": "com.skillshots.app",
      "permissions": ["CAMERA", "RECORD_AUDIO", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "http://localhost:4000"
    }
  }
}
