{
  "name": "@skill-shots/mobile",
  "version": "0.0.0",
  "private": true,
  "description": "Skill Shots mobile shell — Expo + React Native.",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "echo 'mobile: lint runs via tsc + RN-internal'",
    "test": "vitest run",
    "test:cov": "vitest run --coverage"
  },
  "dependencies": {
    "@skill-shots/shared-types": "workspace:*",
    "expo": "~51.0.39",
    "expo-router": "~3.5.24",
    "expo-status-bar": "~1.12.1",
    "expo-secure-store": "~13.0.2",
    "expo-av": "~14.0.7",
    "expo-image": "~1.13.0",
    "expo-linking": "~6.3.1",
    "expo-constants": "~16.0.2",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-reanimated": "~3.10.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@babel/core": "^7.25.7",
    "@types/react": "~18.2.79",
    "@vitest/coverage-v8": "^2.1.4",
    "typescript": "~5.3.3",
    "vitest": "^2.1.4"
  }
}
